// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Stock {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?  @db.Text
  tag         String?  @db.VarChar(100)
  price_label String?  @db.VarChar(100)
  detail_text String?  @db.VarChar(255)
  pub_date    DateTime? @db.Date
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())

  @@map("stocks")
}

model News {
  id         Int      @id @default(autoincrement())
  title      String   @db.VarChar(255)
  excerpt    String?  @db.Text
  tag        String?  @db.VarChar(100)
  image      String?  @db.VarChar(255)
  pub_date   DateTime @db.Date
  is_active  Boolean  @default(true)
  sort_order Int      @default(0)
  created_at DateTime @default(now())

  @@map("news")
}

model Review {
  id          Int      @id @default(autoincrement())
  type        ReviewType @default(slider)
  image       String?  @db.VarChar(255)
  review_text String?  @db.Text
  caption     String?  @db.Text
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  @@map("reviews")
}

enum ReviewType {
  slider
  gratitude
}

model GalleryPhoto {
  id          Int      @id @default(autoincrement())
  filename    String   @db.VarChar(255)
  uploaded_at DateTime @default(now())

  @@map("gallery_photos")
}

model CertificateOrder {
  id               Int      @id @default(autoincrement())
  certificate_name String   @db.VarChar(255)
  certificate_price Float
  full_name        String   @db.VarChar(255)
  phone            String   @db.VarChar(50)
  email            String   @db.VarChar(255)
  comment          String?  @db.Text
  status           String   @default("Новый") @db.VarChar(50)
  created_at       DateTime @default(now())

  @@map("certificate_orders")
}
